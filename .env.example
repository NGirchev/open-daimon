# Telegram
TELEGRAM_USERNAME=your_bot_username
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=

# Admin
ADMIN_TELEGRAM_ID=
ADMIN_REST_EMAIL=

# AI
# OpenRouter: get a free API key at https://openrouter.ai/keys
OPENROUTER_KEY=your_openrouter_api_key
# Serper: optional web search, get a free key at https://serper.dev
SERPER_KEY=
# Ollama: base URL for local Ollama instance (used when provider-type: OLLAMA)
OLLAMA_BASE_URL=http://localhost:11434

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opendaimon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password

# SonarQube (for Cursor MCP; optional)
SONARQUBE_TOKEN=
SONARQUBE_ORG=your_sonarcloud_org

# User Access Configuration (Telegram)
TELEGRAM_ACCESS_ADMIN_IDS=
TELEGRAM_ACCESS_ADMIN_CHANNELS=
TELEGRAM_ACCESS_VIP_IDS=
TELEGRAM_ACCESS_VIP_CHANNELS=
TELEGRAM_ACCESS_REGULAR_IDS=
TELEGRAM_ACCESS_REGULAR_CHANNELS=

# User Access Configuration (REST)
REST_ACCESS_ADMIN_EMAILS=
REST_ACCESS_VIP_EMAILS=
REST_ACCESS_REGULAR_EMAILS=

# Active Docker Compose service profiles (comma-separated)
# Available: monitoring (Prometheus+Grafana), logging (ELK), storage (MinIO)
COMPOSE_PROFILES=monitoring
