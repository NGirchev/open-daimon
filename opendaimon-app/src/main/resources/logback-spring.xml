<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Exception message-only converter: cause chain without stack frames or suppressed exceptions -->
    <conversionRule conversionWord="exmsg"
                    converterClass="io.github.ngirchev.opendaimon.logging.ExceptionMessageConverter"/>

    <!-- Pattern with limited stacktrace (first 15 lines) -->
    <property name="CONSOLE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n%ex{15}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Shorter stacktraces for Spring AI and Reactor -->
    <!-- MessageAggregator and Spring AI retry — exception cause chain only (no stack frames) -->
    <logger name="org.springframework.ai.chat.model.MessageAggregator" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE_NO_STACKTRACE"/>
    </logger>
    <logger name="org.springframework.ai.retry" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE_NO_STACKTRACE"/>
    </logger>

    <!-- Application loggers with noisy stacktraces — exception cause chain only (no stack frames) -->
    <logger name="io.github.ngirchev.opendaimon.common.service.AIUtils" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE_NO_STACKTRACE"/>
    </logger>
    <logger name="io.github.ngirchev.opendaimon.telegram.command.handler.impl.MessageTelegramCommandHandler" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE_NO_STACKTRACE"/>
    </logger>

    <logger name="reactor.core.publisher" level="WARN"/>

    <logger name="org.springframework.web.reactive.function.client" level="WARN"/>

    <!-- Appender with exception cause chain only (no stack frames, no suppressed) -->
    <appender name="CONSOLE_NO_STACKTRACE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n%exmsg%nopex</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
