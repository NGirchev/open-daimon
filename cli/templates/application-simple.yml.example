# application-simple.yml — user-editable overrides for OpenDaimon.
#
# This file is created by the setup wizard from one of three templates:
#   application-simple-openrouter.yml  — OpenRouter only
#   application-simple-ollama.yml      — Ollama only
#   application-simple-both.yml        — OpenRouter + Ollama
#
# It is mounted into the Docker container and applied on top of the defaults
# in application.yml. Edit it to customise models, logging, and limits
# without rebuilding the image. Restart the container to apply changes:
#
#   docker compose restart opendaimon-app
#
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Model List ─────────────────────────────────────────────────────────────
# Override the model list shown to users in the Telegram /model command.
# provider-type: OPENAI (OpenRouter) | OLLAMA
# capabilities: AUTO, CHAT, TOOL_CALLING, WEB, SUMMARIZATION, EMBEDDING, VISION, FREE
#
# open-daimon:
#   ai:
#     spring-ai:
#       openrouter-auto-rotation:
#         models:
#           enabled: false          # Set true to auto-rotate free OpenRouter models
#       models:
#         list:
#           - name: "openrouter/auto"
#             capabilities: [AUTO, CHAT, TOOL_CALLING, WEB, SUMMARIZATION, VISION]
#             provider-type: OPENAI
#             priority: 3
#             allowed-roles: [ADMIN, VIP]
#
#           # Example free OpenRouter model:
#           - name: "google/gemini-2.0-flash-exp:free"
#             capabilities: [CHAT, TOOL_CALLING, WEB, VISION, FREE]
#             provider-type: OPENAI
#             priority: 1
#             # allowed-roles not set — accessible to all roles
#
#           # Example Ollama model:
#           - name: "qwen2.5:7b"
#             capabilities: [AUTO, CHAT, TOOL_CALLING, SUMMARIZATION]
#             provider-type: OLLAMA
#             priority: 1
#             max-reasoning-tokens: 0
#             think: false
#
#           - name: "nomic-embed-text:v1.5"
#             capabilities: [EMBEDDING]
#             provider-type: OLLAMA
#             priority: 1

# ── Storage ───────────────────────────────────────────────────────────────────
# Enable file/image upload support (requires 'storage' Docker Compose profile).
#
# open-daimon:
#   common:
#     storage:
#       enabled: true
#   telegram:
#     file-upload:
#       enabled: true

# ── Bulkhead Limits ───────────────────────────────────────────────────────────
# Adjust concurrent request limits per user tier.
#
# open-daimon:
#   common:
#     bulkhead:
#       instances:
#         ADMIN:
#           maxConcurrentCalls: 10
#           maxWaitDuration: 1s
#         VIP:
#           maxConcurrentCalls: 5
#           maxWaitDuration: 1s
#         REGULAR:
#           maxConcurrentCalls: 1
#           maxWaitDuration: 500ms

# ── Token Limits ──────────────────────────────────────────────────────────────
#
# open-daimon:
#   ai:
#     spring-ai:
#       max-total-prompt-tokens: 32000
#       max-user-message-tokens: 4000
#       max-output-tokens: 4000

# ── Logging ───────────────────────────────────────────────────────────────────
#
# logging:
#   level:
#     io.github.ngirchev.opendaimon.ai.springai.rest: DEBUG
#     io.github.ngirchev.opendaimon.telegram: DEBUG

# ── Ollama Base URL ───────────────────────────────────────────────────────────
# Only needed when using Ollama provider.
# Inside Docker, use host.docker.internal to reach your machine.
#
# spring:
#   ai:
#     ollama:
#       base-url: ${OLLAMA_BASE_URL:http://host.docker.internal:11434}
