# Line endings: always LF in the repo for cross-platform (Linux, Mac, Windows).
# Ensures no spurious "modified" files when switching machines.
* text=auto

# Text files, normalize to LF
*.java text eol=lf
*.kt text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.mdc text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.cmd text eol=lf
*.ps1 text eol=lf
*.gradle text eol=lf
*.groovy text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Binary files
*.jar binary
*.war binary
*.ear binary
*.class binary
*.so binary
*.dll binary
*.exe binary
*.zip binary
*.tar binary
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
